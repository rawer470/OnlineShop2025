@model Category

@{
    ViewData["Title"] = "Delete Category";
}

<h1>Delete Category</h1>

<form asp-action="Delete" method="post" class="form-group">
    <div>
        <input class="form-control" type="text" asp-for="Name" disabled/>
    </div>
    <div>
        <input class="form-control" type="text" asp-for="DisplayOrder" disabled/>
    </div>
    <div>
        <input class="btn btn-danger" type="submit" value="Delete"/>
        <a asp-action="Index" class="btn btn-success">Back</a>
    </div>
</form>